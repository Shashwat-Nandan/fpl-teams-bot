{
  "name": "fpl-manager-crawler",
  "version": "1.0.0",
  "description": "Crawls the FPL Overall league to build a searchable manager directory (player_name, team_name, team_id).",
  "main": "src/index.js",
  "bin": {
    "fpl-crawler": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "test-run": "node src/index.js --max-pages 3",
    "export": "node src/export.js",
    "stats": "node src/stats.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0"
  },
  "engines": {
    "node": ">=18"
  },
